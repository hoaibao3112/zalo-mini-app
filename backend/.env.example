# =========================================================================
# ZALO MINI APP BACKEND - TEMPLATE CONFIGURATION (.env.example)
# Sao chép file này thành .env và điền thông tin cấu hình thực tế.
# =========================================================================

# Cấu hình runtime chính
NODE_ENV=development
PORT=5000

# Kết nối cơ sở dữ liệu PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/databasename?schema=public

# Kết nối Redis Cache & Queue
REDIS_URL=redis://:password@127.0.0.1:6379/1

# Khóa JWT bảo mật (Độ dài tối thiểu 32 ký tự)
JWT_SECRET=your_32_characters_jwt_secret_key_here

# Khóa mã hóa Token đối tác (Độ dài đúng 32 ký tự)
TOKEN_ENCRYPTION_KEY=your_exactly_32_chars_key_here

# Khóa mã hóa đối tác HEX format (Độ dài đúng 64 ký tự)
TOKEN_ENCRYPTION_KEY_HEX=your_exactly_64_hex_characters_key_here

# Danh sách các Domain được phép gọi API (Ngăn cách bởi dấu phẩy)
ALLOWED_ORIGINS=https://h5.zdn.vn,https://zalo.me

# URL trỏ sang CRM Backend (Phục vụ proxy uploads và POS proxy)
SALE_FUNNEL_BACKEND_URL=http://localhost:10007
SEPAY_WEBHOOK_SECRET=your_sepay_webhook_secret_min_16_chars

# =========================================================================
# 🔑 BẢO VỆ API KEYS DÙNG CHUNG (TUYỆT ĐỐI KHÔNG ĐỔI TÊN/FORMAT)
# =========================================================================
ZALO_APP_ID=your_zalo_app_id_here
ZALO_APP_SECRET=your_zalo_app_secret_here
NHANH_APP_ID=your_nhanh_app_id_here
NHANH_SECRET_KEY=your_nhanh_secret_key_here
HARAVAN_APP_ID=your_haravan_app_id_here
HARAVAN_APP_SECRET=your_haravan_app_secret_here
